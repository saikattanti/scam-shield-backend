generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String?      @unique
  passwordHash String?
  isGuest      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  analyses     Analysis[]
  feedback     Feedback[]
  scamReports  ScamReport[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id         String     @id @default(uuid())
  userId     String
  sessionKey String     @unique
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  analyses   Analysis[]
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionKey])
  @@index([expiresAt])
  @@map("sessions")
}

model Analysis {
  id             String     @id @default(uuid())
  userId         String
  sessionId      String
  contentHash    String     @db.VarChar(64)
  contentPreview String?    @db.VarChar(120)
  analysisType   String     @default("text")
  riskScore      Float
  riskLevel      String
  category       String
  language       String     @default("en")
  mlPowered      Boolean    @default(true)
  aiConfidence   Float?
  signals        Json?
  createdAt      DateTime   @default(now())
  aiSteps        String?
  approxLat      Float?
  approxLng      Float?
  approxRegion   String?    @db.VarChar(100)
  storedReason   String?    @db.VarChar(200)
  session        Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback       Feedback[]

  @@index([contentHash])
  @@index([createdAt])
  @@index([riskLevel])
  @@index([approxRegion])
  @@map("analyses")
}

model Feedback {
  id         String   @id @default(uuid())
  analysisId String
  userId     String
  isAccurate Boolean
  comment    String?
  createdAt  DateTime @default(now())
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("feedback")
}

model ScamReport {
  id            String   @id @default(uuid())
  userId        String?
  contentHash   String?  @db.VarChar(64)
  scamCategory  String
  platformUsed  String?  @db.VarChar(100)
  amountLost    Float?
  currency      String   @default("INR")
  language      String   @default("en")
  recoverySteps String
  approxLat     Float?
  approxLng     Float?
  approxRegion  String?  @db.VarChar(100)
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([scamCategory])
  @@index([createdAt])
  @@index([approxRegion])
  @@map("scam_reports")
}
