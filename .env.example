# ══════════════════════════════════════════════════════════════
# ScamShield Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ──────────────────────────────────────────────────────────────
# PostgreSQL Database (Supabase / Neon / Railway / etc.)
# ──────────────────────────────────────────────────────────────
# Runtime connection (use PgBouncer pooler for production)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=3

# Direct connection for Prisma migrations only
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────────
# Google Gemini AI (Primary LLM)
# Get a free key at: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────────────────────
# Groq AI (Fallback when Gemini quota is exhausted)
# Free key at: https://console.groq.com — 14,400 req/day FREE
# ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────
# ML Engine URL
# In production, point to your deployed ML service
# ──────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ──────────────────────────────────────────────────────────────
# Frontend Origin (CORS)
# Update this to your deployed frontend URL
# ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Anonymous user/session IDs for unauthenticated scans
# ──────────────────────────────────────────────────────────────
ANON_USER_ID=anon-system
ANON_SESSION_ID=anon-session
